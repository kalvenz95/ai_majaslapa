# ============================================================
# CHADEMY — Vides mainīgie
# Kopē šo failu uz .env.local un aizpildi visas vērtības
# NEKAD neliec .env.local uz GitHub!
# ============================================================

# ---- CLERK (autentifikācija) --------------------------------
# Reģistrējies: https://clerk.com → Create application
# Clerk Dashboard → API Keys
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
CLERK_SECRET_KEY=sk_test_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Clerk pēc login/logout novirzīšana
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/login
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/register
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=/dashboard
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL=/dashboard

# Clerk Webhook secret (Settings → Webhooks → Add endpoint)
# Endpoint URL: https://tava-majaslapa.lv/api/webhooks/clerk
CLERK_WEBHOOK_SECRET=whsec_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ---- STRIPE (maksājumi) ------------------------------------
# Reģistrējies: https://stripe.com → Dashboard → Developers → API Keys
STRIPE_SECRET_KEY=sk_test_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Stripe Webhook secret (Dashboard → Webhooks → Add endpoint → Reveal signing secret)
# Endpoint URL: https://tava-majaslapa.lv/api/stripe/webhook
# Events: customer.subscription.created, customer.subscription.updated,
#         customer.subscription.deleted, invoice.payment_succeeded, invoice.payment_failed
STRIPE_WEBHOOK_SECRET=whsec_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Stripe Product Price ID (Dashboard → Products → izveidot 3 produktus)
# Satura Speciālists — €29/mēn
STRIPE_PRICE_PAMATI=price_xxxxxxxxxxxxxxxxxxxxxxxx
# Digitālais Speciālists — €59/mēn
STRIPE_PRICE_IZAUGSME=price_xxxxxxxxxxxxxxxxxxxxxxxx
# AI Aģentu Eksperts — €149/mēn
STRIPE_PRICE_MEISTARS=price_xxxxxxxxxxxxxxxxxxxxxxxx

# ---- DATUBĀZE (Supabase) -----------------------------------
# Reģistrējies: https://supabase.com → New project
# Project Settings → Database → Connection string (URI)
DATABASE_URL="postgresql://postgres:[YOUR-PASSWORD]@db.xxxxxxxxxxxx.supabase.co:5432/postgres?pgbouncer=true"
DIRECT_URL="postgresql://postgres:[YOUR-PASSWORD]@db.xxxxxxxxxxxx.supabase.co:5432/postgres"

# ---- E-PASTS (Resend) --------------------------------------
# Reģistrējies: https://resend.com → API Keys → Create API Key
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
RESEND_FROM_EMAIL=noreply@chademy.lv

# ---- VISPĀRĪGI ---------------------------------------------
NEXT_PUBLIC_APP_URL=http://localhost:3000
# Uz Vercel mainīt uz: https://chademy.lv

# ---- HOSTINGER DOMĒNA SAVIENOŠANA AR VERCEL ----------------
# 1. Hostinger → DNS → pievieno A record: @ → 76.76.21.21
# 2. VAI: mainīt Nameservers uz ns1.vercel-dns.com + ns2.vercel-dns.com
# 3. Vercel → Project → Settings → Domains → pievieno chademy.lv
# Supabase datubāze nav saistīta ar domēnu — tā ir atsevišķa mākoņa DB
